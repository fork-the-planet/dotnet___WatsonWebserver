<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.1;net462;net48;net8.0;net10.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Version>7.0.14</Version>
    <Description>Async-first WebSocket client for Watson 7 with whole-message receive semantics, direct ClientWebSocket access, and interop with the Watson webserver WebSocket surface.</Description>
    <PackageReleaseNotes>Initial Watson.Clients package with WatsonWebSocketClient, whole-message receive APIs, raw ClientWebSocket access, exhaustive shared client coverage, and Watson 7 interop validation.</PackageReleaseNotes>
    <Authors>Joel Christner</Authors>
    <Company>Joel Christner</Company>
    <Copyright>(c)2026 Joel Christner</Copyright>
    <PackageProjectUrl>https://github.com/dotnet/WatsonWebserver</PackageProjectUrl>
    <RepositoryUrl>https://github.com/dotnet/WatsonWebserver</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>watson websocket web socket client async messaging</PackageTags>
    <PackageId>Watson.Clients</PackageId>
    <Product>Watson.Clients</Product>
    <PackageLicenseFile>LICENSE.md</PackageLicenseFile>
    <PackageIcon>watson.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>True</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <Title>Watson Clients</Title>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <DocumentationFile>bin\$(Configuration)\$(TargetFramework)\Watson.Clients.xml</DocumentationFile>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="..\..\assets\watson.png" Link="watson.png">
      <Pack>True</Pack>
      <PackagePath></PackagePath>
    </None>
    <None Include="..\..\LICENSE.md" Link="LICENSE.md">
      <Pack>True</Pack>
      <PackagePath></PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net462' Or '$(TargetFramework)' == 'net48'">
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" Version="10.0.0" />
    <PackageReference Include="System.Buffers" Version="4.6.0" />
  </ItemGroup>

</Project>
